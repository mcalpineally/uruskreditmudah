---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Callout from '../../components/mdx/Callout.astro';
import Warning from '../../components/mdx/Warning.astro';
import Takeaways from '../../components/mdx/Takeaways.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((guide) => ({
    params: { slug: guide.id },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);
const formattedDate = guide.data.publishDate.toLocaleDateString('ms-MY', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout title={guide.data.title} description={guide.data.description} image={guide.data.image}>
  <article class="article">
    <header class="article-header">
      <span class="article-category">{guide.data.category}</span>
      <h1>{guide.data.title}</h1>
      <p class="article-meta">Dikemaskini {formattedDate}</p>
    </header>

    <img src={guide.data.image} alt={guide.data.imageAlt || guide.data.title} class="article-featured-image" />

    <div class="article-body">
      <Content components={{ Callout, Warning, Takeaways }} />
    </div>
  </article>
</BaseLayout>

<style>
  .article {
    max-width: 720px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  .article-header {
    margin-bottom: 2rem;
  }

  .article-category {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent-dark);
    font-weight: 600;
  }

  .article-featured-image {
    width: 100%;
    border-radius: 14px;
    margin-bottom: 2rem;
    display: block;
  }

  .article-header h1 {
    margin-top: 0.5rem;
  }

  .article-meta {
    color: #7a7a6e;
    font-size: 0.9rem;
  }

  .article-body {
    font-size: 1.05rem;
  }

  .article-body :global(h2) {
    margin-top: 2.5rem;
    font-size: 1.5rem;
  }

  .article-body :global(h3) {
    margin-top: 2rem;
    font-size: 1.2rem;
  }

  .article-body :global(p) {
    margin: 1rem 0;
  }

  .article-body :global(a) {
    color: var(--color-primary);
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    padding-left: 1.25rem;
  }

  .article-body :global(img) {
    width: 100%;
    border-radius: 12px;
  }
</style>
