---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteConfig from '../config/site.json';
---

<BaseLayout title="Hubungi Kami" description="Ada soalan tentang kad kredit, pinjaman atau pengurusan hutang? Hubungi kami.">
  <section class="page">
    <div class="inner">
      <h1>Hubungi Kami</h1>
      <p>Ada soalan atau cadangan topik? Isi borang di bawah atau emel kami terus.</p>

      <!--
        Form action below is a placeholder. Wire this to a form backend
        (e.g. Formspree, GoHighLevel, or a Cloudflare Worker) once ready —
        the same way KedahHouseForSale.com's forms were connected.
      -->
      <form class="contact-form" action="https://formspree.io/f/REPLACE_ME" method="POST">
        <label>
          Nama
          <input type="text" name="name" required />
        </label>
        <label>
          Emel
          <input type="email" name="email" required />
        </label>
        <label>
          Mesej
          <textarea name="message" rows="5" required></textarea>
        </label>
        <button type="submit">Hantar Mesej</button>
      </form>

      <p class="direct-email">
        Atau emel terus ke <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .inner {
    max-width: 560px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    margin-top: 2rem;
  }

  .contact-form label {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-weight: 500;
    font-size: 0.92rem;
  }

  .contact-form input,
  .contact-form textarea {
    font-family: var(--font-body);
    font-size: 1rem;
    padding: 0.7rem 0.9rem;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    background: #fff;
    color: var(--color-ink);
  }

  .contact-form input:focus,
  .contact-form textarea:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 1px;
  }

  .contact-form button {
    align-self: flex-start;
    background: var(--color-primary);
    color: #fff;
    border: none;
    padding: 0.75rem 1.6rem;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
  }

  .contact-form button:hover {
    background: var(--color-primary-light);
  }

  .direct-email {
    margin-top: 1.5rem;
    color: #5c5c52;
  }
</style>
