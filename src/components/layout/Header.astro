---
import siteConfig from '../../config/site.json';
const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="wordmark">
      <span class="wordmark-main">Urus Kredit</span><span class="wordmark-accent">Mudah</span>
    </a>

    <nav class="nav-desktop" aria-label="Navigasi utama">
      <ul>
        {siteConfig.categories.map((cat) => (
          <li>
            <a
              href={`/panduan/kategori/${cat.slug}/`}
              class={currentPath.includes(cat.slug) ? 'active' : ''}
            >
              {cat.name}
            </a>
          </li>
        ))}
      </ul>
      <a href="/hubungi-kami/" class="cta-button">Hubungi Kami</a>
    </nav>

    <details class="nav-mobile">
      <summary aria-label="Buka menu">
        <span></span><span></span><span></span>
      </summary>
      <ul>
        {siteConfig.categories.map((cat) => (
          <li><a href={`/panduan/kategori/${cat.slug}/`}>{cat.name}</a></li>
        ))}
        <li><a href="/hubungi-kami/">Hubungi Kami</a></li>
      </ul>
    </details>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-paper);
    position: sticky;
    top: 0;
    z-index: 40;
  }

  .header-inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .wordmark {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--color-primary);
    white-space: nowrap;
  }

  .wordmark-accent {
    color: var(--color-accent-dark);
  }

  .nav-desktop {
    display: none;
    align-items: center;
    gap: 2rem;
  }

  .nav-desktop ul {
    display: flex;
    gap: 1.75rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-desktop a {
    text-decoration: none;
    color: var(--color-ink);
    font-weight: 500;
    font-size: 0.95rem;
    padding-bottom: 4px;
    border-bottom: 2px solid transparent;
  }

  .nav-desktop a:hover,
  .nav-desktop a.active {
    border-bottom-color: var(--color-accent);
    color: var(--color-primary);
  }

  .cta-button {
    background: var(--color-primary);
    color: #fff !important;
    padding: 0.55rem 1.1rem;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 600;
    border-bottom: none !important;
  }

  .cta-button:hover {
    background: var(--color-primary-light);
  }

  .nav-mobile {
    position: relative;
  }

  .nav-mobile summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 0.5rem;
  }

  .nav-mobile summary::-webkit-details-marker {
    display: none;
  }

  .nav-mobile summary span {
    width: 22px;
    height: 2px;
    background: var(--color-ink);
    display: block;
  }

  .nav-mobile ul {
    position: absolute;
    right: 0;
    top: calc(100% + 0.5rem);
    background: var(--color-paper);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    list-style: none;
    margin: 0;
    padding: 0.75rem;
    min-width: 200px;
    box-shadow: 0 8px 24px rgba(43, 43, 38, 0.08);
  }

  .nav-mobile a {
    display: block;
    padding: 0.6rem 0.75rem;
    text-decoration: none;
    color: var(--color-ink);
    border-radius: 8px;
    font-size: 0.95rem;
  }

  .nav-mobile a:hover {
    background: var(--color-paper-raised);
  }

  @media (min-width: 860px) {
    .nav-desktop {
      display: flex;
    }
    .nav-mobile {
      display: none;
    }
  }
</style>
