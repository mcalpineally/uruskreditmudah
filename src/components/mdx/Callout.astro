---
interface Props {
  type?: 'green' | 'blue' | 'orange' | 'purple' | 'teal';
  stat?: string;
  source?: string;
}
const { type = 'teal', stat, source } = Astro.props;
---

<div class:list={['callout', `callout-${type}`]}>
  {stat && <span class="callout-stat">{stat}</span>}
  <div class="callout-text"><slot /></div>
  {source && <span class="callout-source">{source}</span>}
</div>

<style>
  .callout {
    border-radius: 14px;
    padding: 1.25rem 1.5rem;
    margin: 1.5rem 0;
    border: 1px solid var(--color-border);
    background: var(--color-paper-raised);
  }

  .callout-teal { border-left: 4px solid var(--color-primary); }
  .callout-green { border-left: 4px solid #5c8a5c; }
  .callout-blue { border-left: 4px solid #4a7ba6; }
  .callout-orange { border-left: 4px solid var(--color-accent); }
  .callout-purple { border-left: 4px solid #7a5c9e; }

  .callout-stat {
    display: block;
    font-family: var(--font-mono);
    font-size: 1.6rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 0.4rem;
  }

  .callout-text {
    color: var(--color-ink);
  }

  .callout-source {
    display: block;
    margin-top: 0.6rem;
    font-size: 0.78rem;
    color: #8a8a7c;
  }
</style>
